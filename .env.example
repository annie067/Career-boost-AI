# Client-side Supabase config used by Vite
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-side Supabase config used by the /api handlers
# If your deployment only exposes one Supabase URL, you can usually reuse the same value here.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# SMTP mail configuration used for verification and reset emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_SECURE=false

# Public app URL used to build email links
APP_URL=http://localhost:5173

# Secret used to sign verification/reset tokens
EMAIL_TOKEN_SECRET=
MAIL_API_KEY=

# Optional restore hooks used by api/_wake.js
FULLSTACK_PROJECT_REF=
FULLSTACK_RESTORE_API_URL=
