{
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "env": {
    "VITE_SUPABASE_URL": "@supabase-url",
    "VITE_SUPABASE_ANON_KEY": "@supabase-anon-key",
    "VITE_GOOGLE_CLIENT_ID": "@google-client-id",
    "VITE_GOOGLE_AUTH_PROXY": "@google-auth-proxy"
  }
}
